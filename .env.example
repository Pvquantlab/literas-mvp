# Supabase ayarları — supabase.com'dan al
# Bu dosyayı .env.local olarak kopyala ve gerçek değerleri yaz

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxx

# Resend — e-posta göndermek için
# resend.com'dan API anahtarı al
RESEND_API_KEY=re_xxxxxxxxxx

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Cron güvenliği — /api/cron/reminders ucunu korur
# Vercel > Settings > Environment Variables'a da AYNI değeri gir.
# Rastgele üret: openssl rand -base64 32
CRON_SECRET=42+vMhNcXnbYrNWvLTLDilGwQ5PJNBPWUtCjDQw0JHw=